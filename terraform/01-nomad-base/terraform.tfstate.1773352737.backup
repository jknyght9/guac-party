                  "value": 0,
                  "type": "number"
                }
              },
              {
                "type": "get_attr",
                "value": "data"
              }
            ]
          ],
          "private": "bnVsbA==",
          "dependencies": [
            "random_password.keepalived_mgmt_passwd"
          ]
        },
