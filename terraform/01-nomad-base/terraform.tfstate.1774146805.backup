            "source_raw": [
              {
                "data": "#cloud-config\nhostname: nomad-sauron.internal\nfqdn: nomad-sauron.internal.localdomain\nmanage_etc_hosts: true\n\nusers:\n  - name: ubuntu\n    shell: /bin/bash\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    ssh_authorized_keys:\n      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMB6Cj1ero7AjVJiaFj+GEiw7zJHWKZFiu/zl3NHIHgd guac-party-automation\n    groups: [docker]\n\nwrite_files:\n  - path: /etc/nomad.d/nomad.hcl\n    permissions: \"0644\"\n    content: |\n      datacenter = \"dc1\"\n      data_dir   = \"/opt/consul/data\"\n      node_name  = \"sauron.internal\"\n      bind_addr  = \"0.0.0.0\"\n      client_addr = \"0.0.0.0\" # So Docker containers can reach it\n      \n      server = true\n      bootstrap_expect = 3\n      \n      # Use the same retry_join logic from Nomad\n      retry_join = [\"192.168.100.87\", \"192.168.100.88\", \"192.168.100.89\"]\n      \n      # Important for Patroni/Vault integration\n      connect {\n        enabled = true\n      }\n      \n      ui_config {\n        enabled = true\n      }\n  - path: /etc/consul.d/consul.hcl\n    permissions: \"0644\"\n    content: |\n      datacenter = \"dc1\"\n      data_dir   = \"/opt/nomad/data\"\n      name       = \"sauron.internal\"\n      bind_addr  = \"0.0.0.0\"\n      \n      # Each nomad node will point internally at its own vault instance\n      vault {\n        enabled = true\n        address = \"http://sauron.internal:8200\"\n        task_token_ttl = \"1h\"\n        \n        default_identity {\n          aud = [\"vault.io\"]\n          ttl = \"1h\"\n        }\n      }\n      \n      consul {\n        address = \"127.0.0.1:8500\"\n      }\n      \n      server {\n        enabled          = true\n        bootstrap_expect = 3\n      \n        server_join {\n          retry_join = [\"192.168.100.87\", \"192.168.100.88\", \"192.168.100.89\"]\n        }\n        oidc_issuer = \"http://172.17.0.1:4646\"\n      \n      }\n      \n      client {\n        enabled = true\n      \n        host_volume \"vault\" {\n          path      = \"/opt/volumes/vault\"\n          read_only = false\n        }\n      \n        host_volume \"authentik-db\" {\n          path      = \"/opt/volumes/authentik-db\"\n          read_only = false\n        }\n      \n        host_volume \"guacamole-db\" {\n          path      = \"/opt/volumes/guacamole-db\"\n          read_only = false\n        }\n      }\n      \n      plugin \"docker\" {\n        config {\n          allow_privileged = true\n      \n          volumes {\n            enabled = true\n          }\n      \n          allow_caps = [\n            \"audit_write\", \"chown\", \"dac_override\", \"fowner\", \"fsetid\", \"kill\", \"mknod\", \n            \"net_bind_service\", \"setfcap\", \"setgid\", \"setpcap\", \"setuid\", \"sys_chroot\", \n            \"ipc_lock\"\n          ]\n        }\n      }\n      \n  - path: /etc/keepalived/keepalived.conf\n    permissions: \"0644\"\n    content: |\n      # Template file used by to install keepalived. Note that this file is not tf or hcl.\n      # This is purely Linux config file\n      global_defs {\n          script_user ubuntu\n          enable_script_security\n      }\n      vrrp_script check_traefik {\n          # This script checks if Traefik is actually responding on port 80\n          script \"/bin/sh -c '/usr/bin/curl -s -f http://127.0.0.1:8080/api/rawdata \u003e /dev/null'\"\n          interval 2  # Check every 2 seconds\n          weight 20   # If it passes, add 20 to priority\n      \n          init_wait 60\n      }\n      \n      vrrp_instance VI_1 {\n          state BACKUP          # Start as BACKUP on all nodes to let priority decide\n          interface eth0        # Double-check this matches your 'ip addr' (e.g., ens18)\n          virtual_router_id 51  # Must be the same on all 3 nodes\n          priority 20          # Set to 100 on Node 1, 90 on Node 2, 80 on Node 3\n      \n          advert_int 1\n      \n          authentication {\n              auth_type PASS\n              auth_pass YmenCJ6vOA6?6K_?t!  # Simple password for the nodes to trust each other\n          }\n      \n          virtual_ipaddress {\n              192.168.100.100  \n          }\n      \n          track_script {\n              check_traefik\n          }\n      }\n  - path: /etc/systemd/resolved.conf\n    permissions: \"0644\"\n    content: |\n      [Resolve]\n      DNS=127.0.0.1\n      FallbackDNS=192.168.100.1 1.1.1.1\n      DNSStubListener=no\n\nruncmd:\n  - systemctl restart nomad\n  - systemctl enable nomad\n  - systemctl restart consul\n  - systemctl enable consul\n  - systemctl restart keepalived\n  - systemctl enabled keepalived\n  - systemctl restart systemd-resolved",
