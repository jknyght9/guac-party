# Proxmox cluster nodes (comma-separated hostnames or IPs)
PVE_NODES=pve1.example.com,pve2.example.com,pve3.example.com

# Proxmox API credentials (generated by bootstrap)
PVE_API_URL=https://pve1.example.com:8006
PVE_API_TOKEN_ID=terraform@pve!terraform
PVE_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SDN configuration
SDN_ZONE_NAME=guestzone
SDN_VNET_NAME=guestvnet
SDN_SUBNET_CIDR=10.10.0.0/24
SDN_GATEWAY=10.10.0.1

# Management network for Nomad VMs
MGMT_BRIDGE=vmbr0
MGMT_SUBNET_CIDR=192.168.1.0/24
MGMT_GATEWAY=192.168.1.1
NOMAD_IP_START=192.168.1.50

# Internal DNS domain
INTERNAL_DOMAIN=internal

# VM template settings
VM_TEMPLATE_NAME=ubuntu-nomad-template
VM_CORES=4
VM_MEMORY=8192
VM_DISK_SIZE=50
